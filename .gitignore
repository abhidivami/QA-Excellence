# ─── macOS ────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# ─── Node.js ──────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Test results ─────────────────────────────────────
# JSON reports are large and unreadable — gitignored
**/results/*.json

# HTML reports and console logs are committed so results
# are visible on GitHub after every test run
# **/results/*.html  ← visible
# **/results/*.log   ← visible

# ─── IDE ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Secrets / environment files ──────────────────────
.env
.env.*
*.env
